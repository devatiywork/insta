{
  "name": "insta-tg-bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Telegram bot for downloading Instagram public posts and reels",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/main.js",
    "dev": "tsx watch src/main.ts",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@grammyjs/auto-retry": "^2.0.2",
    "grammy": "^1.30.0",
    "pino": "^9.5.0"
  },
  "devDependencies": {
    "@types/node": "^20.16.10",
    "pino-pretty": "^11.3.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}
