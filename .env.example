# Telegram bot token from @BotFather
BOT_TOKEN=123456:ABC-DEF...

# pino log level: trace | debug | info | warn | error
LOG_LEVEL=info

# Admin Telegram user ids (comma-separated). REQUIRED — at least one.
# Admins always have access and can add/remove other users via the bot.
# How to get your id: write to @userinfobot in Telegram.
ADMIN_USER_IDS=123456789

# Path to JSON storage with allowed users + per-user prefs.
# Inside Docker keep it under /app/data so the volume persists it.
STORAGE_PATH=data/storage.json

# Instagram cookies — REQUIRED in 2026, IG blocks all anonymous access.
# How to get: log into instagram.com in your browser → DevTools (F12)
# → Application/Storage → Cookies → https://www.instagram.com → copy
# the values for "sessionid" and "csrftoken" (and ds_user_id, mid if you want).
# Format below — one line, semicolon-separated.
# WARNING: use a throw-away IG account, mass-scraping can get it banned.
IG_COOKIES=csrftoken=...; sessionid=...; ds_user_id=...

# TikTok cookies — optional, but recommended to avoid CDN 403 / captcha at scale.
# How to get: log into tiktok.com in your browser → DevTools (F12)
# → Application/Storage → Cookies → https://www.tiktok.com → copy at minimum
# "sessionid", "tt_csrf_token", "ttwid", "tt_chain_token", "msToken".
# Easier: use a Cookie-Editor extension and export as "Header String".
# Format below — one line, semicolon-separated.
# WARNING: use a throw-away TikTok account.
TIKTOK_COOKIES=sessionid=...; tt_csrf_token=...; ttwid=...; tt_chain_token=...; msToken=...
